#!/usr/bin/env bash
# Example hook (PRE) — runs BEFORE all modules.
# Activate: copy the file to hooks/pre.d/<NN>-name.sh (suffix .sh, without .example).
# Order = alphabetical by the NN prefix.
#
# These hooks are executed via `bash <file>`; they run with root privileges.
set -euo pipefail

echo "[pre-hook] Example: insert your own preparations here."
